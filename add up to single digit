#include <stdio.h>

int digitalRoot(int n) {
    while (n >= 10) {   
        int sum = 0;
        while (n > 0) {
            sum += n % 10;  
            n /= 10;       
        }
        n = sum;
    }
    return n;
}

int main() {
    int num = 9875;
    printf("%d", digitalRoot(num));
    return 0;
}

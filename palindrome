#include <stdio.h>

int main()
{
    int num, rev = 0, temp, digit;

    printf("enter a value: ");
    scanf("%d", &num);

    temp = num;

    while (num > 0)
    {
        digit = num % 10;
        rev = rev * 10 + digit;
        num = num / 10;
    }

    if (temp == rev)
    {
        printf("%d is a palindrome", temp);
    }
    else
    {
        printf("not a palindrome");
    }

    return 0;
}
